{
  "headers": [
    {
      "source": "/(.*).(png|jpg|jpeg|webp|mp4|webm|svg|js|css)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
